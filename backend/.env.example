# ============================================================
# SafeHer Backend – Environment Variables Template
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ============================================================

# --- Database (Supabase PostgreSQL) --------------------------
# ⚠️ USE THE SESSION POOLER URL — NOT the Direct Connection!
# The Pooler URL is PERMANENT and never changes, even after pause/wake.
#
# How to get it (one-time setup):
#   1. Go to: Supabase Dashboard → Settings → Database
#   2. Select "Connection Pooling" tab → Session mode
#   3. Copy the URI and paste below
#
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.co:5432/postgres

# --- Supabase Auto-Wake (Free Tier) --------------------------
# Get a personal access token from: https://supabase.com/dashboard/account/tokens
# Your project ref is the subdomain in your Supabase URL (e.g., "mzeqleiwqnweccgmymxc")
SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token_here
SUPABASE_PROJECT_REF=your_project_ref_here

# --- Authentication ------------------------------------------
SECRET_KEY=change-me-to-a-random-string
JWT_SECRET_KEY=jwt-change-me-to-a-random-string
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7

# --- AI / Gemini ---------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# --- Twilio SMS (optional) -----------------------------------
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+1234567890

# --- Flask ---------------------------------------------------
FLASK_ENV=development
PORT=5000
